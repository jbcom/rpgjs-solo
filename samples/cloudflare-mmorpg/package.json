{
  "name": "@rpgjs/sample-cloudflare-mmorpg",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "RPG_TYPE=mmorpg vite build",
    "dev": "concurrently -k -n worker,vite \"pnpm dev:worker\" \"pnpm dev:vite\"",
    "dev:vite": "vite",
    "dev:worker": "wrangler dev --port 8787",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "publish:maps": "tsx src/publish-maps.ts",
    "test": "vitest run",
    "types": "wrangler types ./src/worker-configuration.d.ts"
  },
  "dependencies": {
    "@rpgjs/client": "workspace:*",
    "@rpgjs/server": "workspace:*",
    "@rpgjs/tiledmap": "workspace:*",
    "@rpgjs/vite": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.5.41",
    "@vitest/runner": "2.1.9",
    "@vitest/snapshot": "2.1.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.2.1",
    "esbuild": "0.28.1",
    "tsx": "^4.22.4",
    "vite": "8.0.16",
    "vitest": "2.1.9",
    "wrangler": "3.100.0"
  }
}
