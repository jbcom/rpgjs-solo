<Ellipse 
    x={shadow().x} 
    y={shadow().y} 
    width={shadow().width} 
    height={shadow().height} 
    color="black" 
    blur={3}
    alpha={0.5}
/>

<script>
    import { computed } from "canvasengine";

    const { object } = defineProps();

    const hitbox = object().hitbox;
    const shadow = computed(() => {
        const width = hitbox().w * 1.15;
        const height = Math.max(8, hitbox().h * 0.35);
        return {
            x: (hitbox().w - width) / 2,
            y: hitbox().h + 2,
            width,
            height,
        }
    })
</script>
