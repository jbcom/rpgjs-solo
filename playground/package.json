{
  "name": "@rpgjs/playground",
  "version": "1.0.0-beta.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:launcher": "vite",
    "build": "node scripts/generate-games.mjs && vite build",
    "preview": "vite preview",
    "dev:action-battle": "pnpm --dir games/action-battle dev",
    "build:action-battle": "pnpm --dir games/action-battle build",
    "dev:projectiles": "pnpm --dir games/projectiles dev",
    "build:projectiles": "pnpm --dir games/projectiles build",
    "dev:studio": "pnpm --dir games/studio dev",
    "build:studio": "pnpm --dir games/studio build",
    "dev:tiled": "pnpm --dir games/tiled dev",
    "build:tiled": "pnpm --dir games/tiled build",
    "dev:v4-compat": "pnpm --dir games/v4-compat dev",
    "build:v4-compat": "pnpm --dir games/v4-compat build",
    "dev:vue-gui": "pnpm --dir games/vue-gui dev",
    "build:vue-gui": "pnpm --dir games/vue-gui build"
  },
  "devDependencies": {
    "vite": "^8.0.13"
  }
}
