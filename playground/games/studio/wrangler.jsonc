{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "rpgjs-playground-studio",
  "main": "src/entries/cloudflare.ts",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "RPGJS_ROOMS",
        "class_name": "RpgServerDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RpgServerDurableObject"]
    }
  ],
  "env": {
    "staging": { "name": "rpgjs-playground-studio-staging" },
    "production": { "name": "rpgjs-playground-studio-production" }
  }
}
