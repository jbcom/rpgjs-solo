{
  "name": "@jbcom/rpgjs-solo-action-battle",
  "version": "5.0.0-beta.26.solo.6",
  "description": "Transport-free deterministic action combat for RPGJS Solo",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "node ../../bin/require-pnpm-publish.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:boundary": "node scripts/verify-boundary.mjs"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://git.local.jonbogaty.com/api/packages/jbcom/npm/"
  },
  "dependencies": {
    "@jbcom/rpgjs-solo": "workspace:5.0.0-beta.26.solo.5"
  },
  "devDependencies": {
    "@typescript/typescript6": "6.0.2",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.10"
  }
}
