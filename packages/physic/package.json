{
  "name": "@rpgjs/physic",
  "version": "5.0.0-alpha.41",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "benchmark": "tsx benchmarks/cli/benchmark.ts",
    "benchmark:all": "tsx benchmarks/cli/benchmark.ts all",
    "benchmark:1000": "tsx benchmarks/cli/benchmark.ts 1000",
    "benchmark:10000": "tsx benchmarks/cli/benchmark.ts 10000",
    "benchmark:collisions": "tsx benchmarks/cli/benchmark.ts collisions",
    "benchmark:regions": "tsx benchmarks/cli/benchmark.ts regions",
    "example": "vite --mode example",
    "example:dev": "vite --mode example",
    "example:rpg": "vite --mode rpg",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc"
  },
  "keywords": [
    "physics",
    "2d",
    "top-down",
    "rpg",
    "game",
    "collision",
    "deterministic"
  ],
  "author": "Samuel Ronce",
  "license": "MIT",
  "description": "A deterministic 2D top-down physics library for RPG, sandbox and MMO games",
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.0.7",
    "@vitest/ui": "^4.0.7",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.7"
  }
}
