{
  "name": "@jbcom/rpgjs-solo-vite",
  "version": "5.0.0-beta.26.solo.0",
  "description": "Vite production-boundary enforcement for RPGJS Solo games",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://git.local.jonbogaty.com/api/packages/jbcom/npm/"
  },
  "peerDependencies": {
    "vite": "8.1.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "8.1.1",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
