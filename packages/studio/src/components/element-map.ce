<Container  zIndex={zIndex} onBeforeDestroy>
    <Container>
        @for (spritePart of spriteParts) {
            <Sprite
                image={image}
                rectangle={spritePart.rectangle}
                x={spritePart.x}
                y={spritePart.y}
                width={spritePart.width}
                height={spritePart.height}
            
            />
        }
        @if (lightSpotOverlay.enabled) {
            <LightSpot
                enabled={lightSpotOverlay.enabled}
                x={lightSpotOverlay.centerX}
                y={lightSpotOverlay.centerY}
                radius={lightSpotOverlay.radius}
                intensity={lightSpotOverlay.intensity}
                flicker={lightSpotOverlay.flicker}
                flickerSpeed={lightSpotOverlay.flickerSpeed}
                style={lightSpotOverlay.style}
                zIndex={lightSpotOverlay.zIndex}
            />
        }
        @if (hasShadow) {
            <Ellipse 
                x={shadow.x} 
                y={shadow.y} 
                width={shadow.width} 
                height={shadow.height} 
                color="black" 
                blur={10} 
                alpha={0.5}
                anchor={1}
            />
        }
    </Container>
</Container>

<script>
import { mount, signal } from "canvasengine"
import { inject, RpgClientEngine } from "@rpgjs/client"
import LightSpot from "./light-spot.ce"

const {
    id,
    image,
    rect,
    drawIn,
    hitbox,
    zIndexOffset,
    hasShadow,
    scale,
    drawRule,
    lightSpot
} = defineProps({
    scale: {
        type: Number,
        default: 1
    }
})

const engine = inject(RpgClientEngine)

const toFiniteNumber = (value, fallback = null) => {
    if (typeof value !== "number" || !Number.isFinite(value)) {
        return fallback
    }
    return value
}

const clampMin = (value, min = 1) => Math.max(min, Math.round(value))
const clamp = (value, min, max) => Math.max(min, Math.min(max, value))

const normalizeScale = (value) => {
    if (typeof value === "number" && Number.isFinite(value) && value > 0) {
        return { x: value, y: value }
    }
    if (Array.isArray(value)) {
        const x = toFiniteNumber(value[0], 1)
        const y = toFiniteNumber(value[1], x)
        return {
            x: x && x > 0 ? x : 1,
            y: y && y > 0 ? y : 1
        }
    }
    if (value && typeof value === "object") {
        const sx = toFiniteNumber(value.x, 1)
        const sy = toFiniteNumber(value.y, sx)
        return {
            x: sx && sx > 0 ? sx : 1,
            y: sy && sy > 0 ? sy : 1
        }
    }
    return { x: 1, y: 1 }
}

const normalizeLightStyle = (value) => {
    if (value === "soft" || value === "normal" || value === "intense") {
        return value
    }
    return "normal"
}

const lightStyleRadiusScale = (style) => {
    if (style === "soft") return 1.65
    if (style === "intense") return 2.35
    return 2.02
}

const rectangle = {
    x: rect[0],
    y: rect[1],
    width: rect[2],
    height: rect[3]
}

const drawX = toFiniteNumber(drawIn?.[0], 0) ?? 0
const drawY = toFiniteNumber(drawIn?.[1], 0) ?? 0
const drawWidthBase = clampMin(toFiniteNumber(drawIn?.[2], rectangle.width) ?? rectangle.width)
const drawHeightBase = clampMin(toFiniteNumber(drawIn?.[3], rectangle.height) ?? rectangle.height)
const normalizedScale = normalizeScale(scale)
const scaleX = normalizedScale.x
const scaleY = normalizedScale.y
const drawWidth = clampMin(drawWidthBase * scaleX)
const drawHeight = clampMin(drawHeightBase * scaleY)

const normalizeLightSpot = (value) => {
    const defaults = {
        enabled: false,
        x: Math.round(rectangle.width / 2),
        y: Math.round(rectangle.height / 2),
        radius: 50,
        intensity: 95,
        flicker: true,
        flickerSpeed: 13,
        style: "normal"
    }

    if (!value || typeof value !== "object") {
        return defaults
    }

    const source = value
    const maxX = Math.max(0, rectangle.width - 1)
    const maxY = Math.max(0, rectangle.height - 1)
    const maxRadius = Math.max(8, Math.max(rectangle.width, rectangle.height) * 2)

    const normalized = {
        enabled: typeof source.enabled === "boolean" ? source.enabled : true,
        x: Math.round(clamp(toFiniteNumber(source.x, defaults.x), 0, maxX)),
        y: Math.round(clamp(toFiniteNumber(source.y, defaults.y), 0, maxY)),
        radius: Math.round(clamp(toFiniteNumber(source.radius, defaults.radius), 4, maxRadius)),
        intensity: Number(
            clamp(
                toFiniteNumber(source.intensity, defaults.intensity) <= 1
                    ? toFiniteNumber(source.intensity, defaults.intensity) * 100
                    : toFiniteNumber(source.intensity, defaults.intensity),
                0,
                100
            ).toFixed(2)
        ),
        flicker: typeof source.flicker === "boolean" ? source.flicker : defaults.flicker,
        flickerSpeed: Math.round(clamp(toFiniteNumber(source.flickerSpeed, defaults.flickerSpeed), 1, 60)),
        style: normalizeLightStyle(
            typeof source.style === "string"
                ? source.style
                : (typeof source.preset === "string" ? source.preset : defaults.style)
        )
    }

    return normalized
}

const resolvedLightSpot = normalizeLightSpot(lightSpot)

const normalizeRuleRect = (value) => {
    if (!Array.isArray(value) || value.length < 4) return null
    const x = toFiniteNumber(value[0], null)
    const y = toFiniteNumber(value[1], null)
    const width = toFiniteNumber(value[2], null)
    const height = toFiniteNumber(value[3], null)
    if (x === null || y === null || width === null || height === null) return null
    return [Math.round(x), Math.round(y), clampMin(width), clampMin(height)]
}

const normalizeDrawRule = (value) => {
    if (!value) return null
    let source = value

    if (typeof source === "string") {
        try {
            source = JSON.parse(source)
        }
        catch (_error) {
            return null
        }
    }

    if (!source || typeof source !== "object") return null

    const type = source.type
    if (type !== "repeat-axis" && type !== "edge-repeat" && type !== "frame-9slice") {
        return null
    }

    if (!source.rects || typeof source.rects !== "object") {
        return null
    }

    const rects = {}
    Object.entries(source.rects).forEach(([key, rawRect]) => {
        const normalized = normalizeRuleRect(rawRect)
        if (normalized) {
            rects[key] = normalized
        }
    })

    return {
        id: typeof source.id === "string" ? source.id : "",
        type,
        axis: type === "frame-9slice" ? "x" : (source.axis === "y" ? "y" : "x"),
        rects
    }
}

const getRuleSourceRect = (localRect) => {
    if (!localRect || !Array.isArray(localRect)) return null
    const [rawX, rawY, rawW, rawH] = localRect
    if (
        !Number.isFinite(rawX) ||
        !Number.isFinite(rawY) ||
        !Number.isFinite(rawW) ||
        !Number.isFinite(rawH)
    ) {
        return null
    }

    const localX = Math.max(0, Math.min(rectangle.width - 1, Math.round(rawX)))
    const localY = Math.max(0, Math.min(rectangle.height - 1, Math.round(rawY)))
    const localW = Math.max(1, Math.min(rectangle.width - localX, Math.round(rawW)))
    const localH = Math.max(1, Math.min(rectangle.height - localY, Math.round(rawH)))

    return {
        x: rectangle.x + localX,
        y: rectangle.y + localY,
        width: localW,
        height: localH
    }
}

const pushSegment = (segments, sourceRect, x, y, width, height, segmentIndex) => {
    if (!sourceRect || width <= 0 || height <= 0) return
    segments.push({
        key: `${segmentIndex}_${Math.round(x)}_${Math.round(y)}`,
        x,
        y,
        width,
        height,
        rectangle: {
            x: sourceRect.x,
            y: sourceRect.y,
            width: sourceRect.width,
            height: sourceRect.height
        }
    })
}

const drawRepeatedHorizontally = (
    segments,
    sourceRect,
    destX,
    destY,
    targetWidth,
    targetHeight,
    unitWidth,
    segmentIndexRef
) => {
    let offsetX = 0
    while (offsetX < targetWidth - 0.001) {
        const drawSegmentWidth = Math.min(unitWidth, targetWidth - offsetX)
        const srcWidth = Math.max(1, sourceRect.width * (drawSegmentWidth / unitWidth))
        pushSegment(
            segments,
            {
                x: sourceRect.x,
                y: sourceRect.y,
                width: srcWidth,
                height: sourceRect.height
            },
            destX + offsetX,
            destY,
            drawSegmentWidth,
            targetHeight,
            segmentIndexRef.value++
        )
        offsetX += drawSegmentWidth
    }
}

const drawRepeatedVertically = (
    segments,
    sourceRect,
    destX,
    destY,
    targetWidth,
    targetHeight,
    unitHeight,
    segmentIndexRef
) => {
    let offsetY = 0
    while (offsetY < targetHeight - 0.001) {
        const drawSegmentHeight = Math.min(unitHeight, targetHeight - offsetY)
        const srcHeight = Math.max(1, sourceRect.height * (drawSegmentHeight / unitHeight))
        pushSegment(
            segments,
            {
                x: sourceRect.x,
                y: sourceRect.y,
                width: sourceRect.width,
                height: srcHeight
            },
            destX,
            destY + offsetY,
            targetWidth,
            drawSegmentHeight,
            segmentIndexRef.value++
        )
        offsetY += drawSegmentHeight
    }
}

const drawHorizontalSegment = (
    segments,
    sourceRect,
    destX,
    destY,
    segmentWidth,
    segmentHeight,
    fullWidth,
    fromEnd,
    segmentIndexRef
) => {
    if (segmentWidth <= 0 || fullWidth <= 0) return
    const ratio = segmentWidth / fullWidth
    const srcWidth = Math.max(1, sourceRect.width * ratio)
    const srcX = fromEnd ? sourceRect.x + sourceRect.width - srcWidth : sourceRect.x
    pushSegment(
        segments,
        {
            x: srcX,
            y: sourceRect.y,
            width: srcWidth,
            height: sourceRect.height
        },
        destX,
        destY,
        segmentWidth,
        segmentHeight,
        segmentIndexRef.value++
    )
}

const drawVerticalSegment = (
    segments,
    sourceRect,
    destX,
    destY,
    segmentWidth,
    segmentHeight,
    fullHeight,
    fromEnd,
    segmentIndexRef
) => {
    if (segmentHeight <= 0 || fullHeight <= 0) return
    const ratio = segmentHeight / fullHeight
    const srcHeight = Math.max(1, sourceRect.height * ratio)
    const srcY = fromEnd ? sourceRect.y + sourceRect.height - srcHeight : sourceRect.y
    pushSegment(
        segments,
        {
            x: sourceRect.x,
            y: srcY,
            width: sourceRect.width,
            height: srcHeight
        },
        destX,
        destY,
        segmentWidth,
        segmentHeight,
        segmentIndexRef.value++
    )
}

const drawBoxSegment = (
    segments,
    sourceRect,
    destX,
    destY,
    destWidth,
    destHeight,
    fullWidth,
    fullHeight,
    fromEndX,
    fromEndY,
    segmentIndexRef
) => {
    if (destWidth <= 0 || destHeight <= 0 || fullWidth <= 0 || fullHeight <= 0) return
    const widthRatio = destWidth / fullWidth
    const heightRatio = destHeight / fullHeight
    const srcWidth = Math.max(1, sourceRect.width * widthRatio)
    const srcHeight = Math.max(1, sourceRect.height * heightRatio)
    const srcX = fromEndX ? sourceRect.x + sourceRect.width - srcWidth : sourceRect.x
    const srcY = fromEndY ? sourceRect.y + sourceRect.height - srcHeight : sourceRect.y
    pushSegment(
        segments,
        {
            x: srcX,
            y: srcY,
            width: srcWidth,
            height: srcHeight
        },
        destX,
        destY,
        destWidth,
        destHeight,
        segmentIndexRef.value++
    )
}

const drawRepeatedGrid = (
    segments,
    sourceRect,
    destX,
    destY,
    targetWidth,
    targetHeight,
    unitWidth,
    unitHeight,
    segmentIndexRef
) => {
    let offsetY = 0
    while (offsetY < targetHeight - 0.001) {
        const drawSegmentHeight = Math.min(unitHeight, targetHeight - offsetY)
        const srcHeight = Math.max(1, sourceRect.height * (drawSegmentHeight / unitHeight))
        let offsetX = 0
        while (offsetX < targetWidth - 0.001) {
            const drawSegmentWidth = Math.min(unitWidth, targetWidth - offsetX)
            const srcWidth = Math.max(1, sourceRect.width * (drawSegmentWidth / unitWidth))
            pushSegment(
                segments,
                {
                    x: sourceRect.x,
                    y: sourceRect.y,
                    width: srcWidth,
                    height: srcHeight
                },
                destX + offsetX,
                destY + offsetY,
                drawSegmentWidth,
                drawSegmentHeight,
                segmentIndexRef.value++
            )
            offsetX += drawSegmentWidth
        }
        offsetY += drawSegmentHeight
    }
}

const buildSegmentsWithRule = (rule) => {
    if (!rule) return null
    const segments = []
    const segmentIndexRef = { value: 0 }

    if (rule.type === "repeat-axis") {
        const bodyRect = getRuleSourceRect(rule.rects?.body)
        if (!bodyRect) return null

        if (rule.axis === "x") {
            const repeatUnitWidth = Math.max(1, bodyRect.width * scaleX)
            drawRepeatedHorizontally(
                segments,
                bodyRect,
                drawX,
                drawY,
                drawWidth,
                drawHeight,
                repeatUnitWidth,
                segmentIndexRef
            )
            return segments.length > 0 ? segments : null
        }

        const repeatUnitHeight = Math.max(1, bodyRect.height * scaleY)
        drawRepeatedVertically(
            segments,
            bodyRect,
            drawX,
            drawY,
            drawWidth,
            drawHeight,
            repeatUnitHeight,
            segmentIndexRef
        )
        return segments.length > 0 ? segments : null
    }

    if (rule.type === "edge-repeat") {
        const startRect = getRuleSourceRect(rule.rects?.start)
        const middleRect = getRuleSourceRect(rule.rects?.middle)
        const endRect = getRuleSourceRect(rule.rects?.end)
        if (!startRect || !middleRect || !endRect) return null

        if (rule.axis === "x") {
            const startWidth = Math.max(1, startRect.width * scaleX)
            const endWidth = Math.max(1, endRect.width * scaleX)
            const fixedWidth = startWidth + endWidth

            if (fixedWidth <= drawWidth) {
                pushSegment(
                    segments,
                    startRect,
                    drawX,
                    drawY,
                    startWidth,
                    drawHeight,
                    segmentIndexRef.value++
                )
                pushSegment(
                    segments,
                    endRect,
                    drawX + drawWidth - endWidth,
                    drawY,
                    endWidth,
                    drawHeight,
                    segmentIndexRef.value++
                )

                const middleTargetWidth = drawWidth - fixedWidth
                if (middleTargetWidth > 0) {
                    const middleUnitWidth = Math.max(1, middleRect.width * scaleX)
                    drawRepeatedHorizontally(
                        segments,
                        middleRect,
                        drawX + startWidth,
                        drawY,
                        middleTargetWidth,
                        drawHeight,
                        middleUnitWidth,
                        segmentIndexRef
                    )
                }
                return segments.length > 0 ? segments : null
            }

            const ratio = drawWidth / fixedWidth
            const startDrawWidth = Math.max(0, startWidth * ratio)
            const endDrawWidth = Math.max(0, drawWidth - startDrawWidth)
            drawHorizontalSegment(
                segments,
                startRect,
                drawX,
                drawY,
                startDrawWidth,
                drawHeight,
                startWidth,
                false,
                segmentIndexRef
            )
            drawHorizontalSegment(
                segments,
                endRect,
                drawX + startDrawWidth,
                drawY,
                endDrawWidth,
                drawHeight,
                endWidth,
                true,
                segmentIndexRef
            )
            return segments.length > 0 ? segments : null
        }

        const startHeight = Math.max(1, startRect.height * scaleY)
        const endHeight = Math.max(1, endRect.height * scaleY)
        const fixedHeight = startHeight + endHeight

        if (fixedHeight <= drawHeight) {
            pushSegment(
                segments,
                startRect,
                drawX,
                drawY,
                drawWidth,
                startHeight,
                segmentIndexRef.value++
            )
            pushSegment(
                segments,
                endRect,
                drawX,
                drawY + drawHeight - endHeight,
                drawWidth,
                endHeight,
                segmentIndexRef.value++
            )

            const middleTargetHeight = drawHeight - fixedHeight
            if (middleTargetHeight > 0) {
                const middleUnitHeight = Math.max(1, middleRect.height * scaleY)
                drawRepeatedVertically(
                    segments,
                    middleRect,
                    drawX,
                    drawY + startHeight,
                    drawWidth,
                    middleTargetHeight,
                    middleUnitHeight,
                    segmentIndexRef
                )
            }
            return segments.length > 0 ? segments : null
        }

        const ratio = drawHeight / fixedHeight
        const startDrawHeight = Math.max(0, startHeight * ratio)
        const endDrawHeight = Math.max(0, drawHeight - startDrawHeight)
        drawVerticalSegment(
            segments,
            startRect,
            drawX,
            drawY,
            drawWidth,
            startDrawHeight,
            startHeight,
            false,
            segmentIndexRef
        )
        drawVerticalSegment(
            segments,
            endRect,
            drawX,
            drawY + startDrawHeight,
            drawWidth,
            endDrawHeight,
            endHeight,
            true,
            segmentIndexRef
        )
        return segments.length > 0 ? segments : null
    }

    if (rule.type === "frame-9slice") {
        const cornerTL = getRuleSourceRect(rule.rects?.cornerTL)
        const cornerTR = getRuleSourceRect(rule.rects?.cornerTR)
        const cornerBL = getRuleSourceRect(rule.rects?.cornerBL)
        const cornerBR = getRuleSourceRect(rule.rects?.cornerBR)
        const edgeT = getRuleSourceRect(rule.rects?.edgeT)
        const edgeB = getRuleSourceRect(rule.rects?.edgeB)
        const edgeL = getRuleSourceRect(rule.rects?.edgeL)
        const edgeR = getRuleSourceRect(rule.rects?.edgeR)
        const center = getRuleSourceRect(rule.rects?.center)

        if (!cornerTL || !cornerTR || !cornerBL || !cornerBR || !edgeT || !edgeB || !edgeL || !edgeR || !center) {
            return null
        }

        const leftFixed = Math.max(1, Math.max(cornerTL.width, cornerBL.width, edgeL.width) * scaleX)
        const rightFixed = Math.max(1, Math.max(cornerTR.width, cornerBR.width, edgeR.width) * scaleX)
        const topFixed = Math.max(1, Math.max(cornerTL.height, cornerTR.height, edgeT.height) * scaleY)
        const bottomFixed = Math.max(1, Math.max(cornerBL.height, cornerBR.height, edgeB.height) * scaleY)

        const fixedWidth = leftFixed + rightFixed
        const fixedHeight = topFixed + bottomFixed

        const ratioX = fixedWidth > drawWidth ? drawWidth / fixedWidth : 1
        const ratioY = fixedHeight > drawHeight ? drawHeight / fixedHeight : 1

        const leftDraw = Math.max(0, leftFixed * ratioX)
        const rightDraw = ratioX < 1 ? Math.max(0, drawWidth - leftDraw) : rightFixed
        const topDraw = Math.max(0, topFixed * ratioY)
        const bottomDraw = ratioY < 1 ? Math.max(0, drawHeight - topDraw) : bottomFixed

        const middleWidth = Math.max(0, drawWidth - leftDraw - rightDraw)
        const middleHeight = Math.max(0, drawHeight - topDraw - bottomDraw)

        const leftX = drawX
        const middleX = drawX + leftDraw
        const rightX = drawX + drawWidth - rightDraw
        const topY = drawY
        const middleY = drawY + topDraw
        const bottomY = drawY + drawHeight - bottomDraw

        drawBoxSegment(
            segments,
            cornerTL,
            leftX,
            topY,
            leftDraw,
            topDraw,
            leftFixed,
            topFixed,
            false,
            false,
            segmentIndexRef
        )
        drawBoxSegment(
            segments,
            cornerTR,
            rightX,
            topY,
            rightDraw,
            topDraw,
            rightFixed,
            topFixed,
            true,
            false,
            segmentIndexRef
        )
        drawBoxSegment(
            segments,
            cornerBL,
            leftX,
            bottomY,
            leftDraw,
            bottomDraw,
            leftFixed,
            bottomFixed,
            false,
            true,
            segmentIndexRef
        )
        drawBoxSegment(
            segments,
            cornerBR,
            rightX,
            bottomY,
            rightDraw,
            bottomDraw,
            rightFixed,
            bottomFixed,
            true,
            true,
            segmentIndexRef
        )

        if (middleWidth > 0 && topDraw > 0) {
            const edgeTopUnitWidth = Math.max(1, edgeT.width * scaleX)
            drawRepeatedHorizontally(
                segments,
                edgeT,
                middleX,
                topY,
                middleWidth,
                topDraw,
                edgeTopUnitWidth,
                segmentIndexRef
            )
        }

        if (middleWidth > 0 && bottomDraw > 0) {
            const edgeBottomUnitWidth = Math.max(1, edgeB.width * scaleX)
            drawRepeatedHorizontally(
                segments,
                edgeB,
                middleX,
                bottomY,
                middleWidth,
                bottomDraw,
                edgeBottomUnitWidth,
                segmentIndexRef
            )
        }

        if (middleHeight > 0 && leftDraw > 0) {
            const edgeLeftUnitHeight = Math.max(1, edgeL.height * scaleY)
            drawRepeatedVertically(
                segments,
                edgeL,
                leftX,
                middleY,
                leftDraw,
                middleHeight,
                edgeLeftUnitHeight,
                segmentIndexRef
            )
        }

        if (middleHeight > 0 && rightDraw > 0) {
            const edgeRightUnitHeight = Math.max(1, edgeR.height * scaleY)
            drawRepeatedVertically(
                segments,
                edgeR,
                rightX,
                middleY,
                rightDraw,
                middleHeight,
                edgeRightUnitHeight,
                segmentIndexRef
            )
        }

        if (middleWidth > 0 && middleHeight > 0) {
            const centerUnitWidth = Math.max(1, center.width * scaleX)
            const centerUnitHeight = Math.max(1, center.height * scaleY)
            drawRepeatedGrid(
                segments,
                center,
                middleX,
                middleY,
                middleWidth,
                middleHeight,
                centerUnitWidth,
                centerUnitHeight,
                segmentIndexRef
            )
        }

        return segments.length > 0 ? segments : null
    }

    return null
}

const fallbackSpriteParts = [
    {
        key: "default",
        x: drawX,
        y: drawY,
        width: drawWidth,
        height: drawHeight,
        rectangle
    }
]

const normalizedRule = normalizeDrawRule(drawRule)

const mapRange = (value, srcStart, srcSize, destStart, destSize) => {
    if (srcSize <= 0 || destSize <= 0) return destStart
    const ratio = clamp((value - srcStart) / srcSize, 0, 1)
    return destStart + (ratio * destSize)
}

const mapLocalLightSpotToWorld = (rule, localX, localY) => {
    const sourceWidth = Math.max(1, rectangle.width)
    const sourceHeight = Math.max(1, rectangle.height)

    const fallback = {
        x: drawX + ((clamp(localX, 0, sourceWidth) / sourceWidth) * drawWidth),
        y: drawY + ((clamp(localY, 0, sourceHeight) / sourceHeight) * drawHeight)
    }

    if (!rule) return fallback

    if (rule.type === "edge-repeat") {
        const start = rule.rects?.start
        const middle = rule.rects?.middle
        const end = rule.rects?.end
        if (!start || !middle || !end) return fallback

        if (rule.axis === "x") {
            const startSrc = Math.max(1, start[2])
            const endSrc = Math.max(1, end[2])
            const fixedWidth = (startSrc * scaleX) + (endSrc * scaleX)
            const compressRatio = fixedWidth > drawWidth ? drawWidth / fixedWidth : 1
            const startDraw = (startSrc * scaleX) * compressRatio
            const endDraw = (endSrc * scaleX) * compressRatio
            const middleDraw = Math.max(0, drawWidth - startDraw - endDraw)
            const middleSrc = Math.max(1, sourceWidth - startSrc - endSrc)

            let mappedX = fallback.x
            if (localX <= startSrc) {
                mappedX = mapRange(localX, 0, startSrc, drawX, Math.max(1, startDraw))
            }
            else if (localX >= sourceWidth - endSrc) {
                mappedX = mapRange(
                    localX,
                    sourceWidth - endSrc,
                    endSrc,
                    drawX + drawWidth - endDraw,
                    Math.max(1, endDraw)
                )
            }
            else {
                mappedX = mapRange(
                    localX,
                    startSrc,
                    middleSrc,
                    drawX + startDraw,
                    Math.max(1, middleDraw)
                )
            }

            return {
                x: mappedX,
                y: fallback.y
            }
        }

        const startSrc = Math.max(1, start[3])
        const endSrc = Math.max(1, end[3])
        const fixedHeight = (startSrc * scaleY) + (endSrc * scaleY)
        const compressRatio = fixedHeight > drawHeight ? drawHeight / fixedHeight : 1
        const startDraw = (startSrc * scaleY) * compressRatio
        const endDraw = (endSrc * scaleY) * compressRatio
        const middleDraw = Math.max(0, drawHeight - startDraw - endDraw)
        const middleSrc = Math.max(1, sourceHeight - startSrc - endSrc)

        let mappedY = fallback.y
        if (localY <= startSrc) {
            mappedY = mapRange(localY, 0, startSrc, drawY, Math.max(1, startDraw))
        }
        else if (localY >= sourceHeight - endSrc) {
            mappedY = mapRange(
                localY,
                sourceHeight - endSrc,
                endSrc,
                drawY + drawHeight - endDraw,
                Math.max(1, endDraw)
            )
        }
        else {
            mappedY = mapRange(
                localY,
                startSrc,
                middleSrc,
                drawY + startDraw,
                Math.max(1, middleDraw)
            )
        }

        return {
            x: fallback.x,
            y: mappedY
        }
    }

    if (rule.type === "frame-9slice") {
        const cornerTL = rule.rects?.cornerTL
        const cornerTR = rule.rects?.cornerTR
        const cornerBL = rule.rects?.cornerBL
        const cornerBR = rule.rects?.cornerBR
        const edgeT = rule.rects?.edgeT
        const edgeB = rule.rects?.edgeB
        const edgeL = rule.rects?.edgeL
        const edgeR = rule.rects?.edgeR
        if (!cornerTL || !cornerTR || !cornerBL || !cornerBR || !edgeT || !edgeB || !edgeL || !edgeR) {
            return fallback
        }

        const leftSrc = Math.max(1, Math.max(cornerTL[2], cornerBL[2], edgeL[2]))
        const rightSrc = Math.max(1, Math.max(cornerTR[2], cornerBR[2], edgeR[2]))
        const topSrc = Math.max(1, Math.max(cornerTL[3], cornerTR[3], edgeT[3]))
        const bottomSrc = Math.max(1, Math.max(cornerBL[3], cornerBR[3], edgeB[3]))

        const leftFixed = leftSrc * scaleX
        const rightFixed = rightSrc * scaleX
        const topFixed = topSrc * scaleY
        const bottomFixed = bottomSrc * scaleY
        const fixedWidth = leftFixed + rightFixed
        const fixedHeight = topFixed + bottomFixed

        const ratioX = fixedWidth > drawWidth ? drawWidth / fixedWidth : 1
        const ratioY = fixedHeight > drawHeight ? drawHeight / fixedHeight : 1

        const leftDraw = leftFixed * ratioX
        const rightDraw = ratioX < 1 ? Math.max(0, drawWidth - leftDraw) : rightFixed
        const topDraw = topFixed * ratioY
        const bottomDraw = ratioY < 1 ? Math.max(0, drawHeight - topDraw) : bottomFixed

        const middleSrcWidth = Math.max(1, sourceWidth - leftSrc - rightSrc)
        const middleSrcHeight = Math.max(1, sourceHeight - topSrc - bottomSrc)
        const middleDrawWidth = Math.max(0, drawWidth - leftDraw - rightDraw)
        const middleDrawHeight = Math.max(0, drawHeight - topDraw - bottomDraw)

        let mappedX = fallback.x
        if (localX <= leftSrc) {
            mappedX = mapRange(localX, 0, leftSrc, drawX, Math.max(1, leftDraw))
        }
        else if (localX >= sourceWidth - rightSrc) {
            mappedX = mapRange(
                localX,
                sourceWidth - rightSrc,
                rightSrc,
                drawX + drawWidth - rightDraw,
                Math.max(1, rightDraw)
            )
        }
        else {
            mappedX = mapRange(
                localX,
                leftSrc,
                middleSrcWidth,
                drawX + leftDraw,
                Math.max(1, middleDrawWidth)
            )
        }

        let mappedY = fallback.y
        if (localY <= topSrc) {
            mappedY = mapRange(localY, 0, topSrc, drawY, Math.max(1, topDraw))
        }
        else if (localY >= sourceHeight - bottomSrc) {
            mappedY = mapRange(
                localY,
                sourceHeight - bottomSrc,
                bottomSrc,
                drawY + drawHeight - bottomDraw,
                Math.max(1, bottomDraw)
            )
        }
        else {
            mappedY = mapRange(
                localY,
                topSrc,
                middleSrcHeight,
                drawY + topDraw,
                Math.max(1, middleDrawHeight)
            )
        }

        return { x: mappedX, y: mappedY }
    }

    return fallback
}

const lightScaleX = drawWidth / Math.max(1, rectangle.width)
const lightScaleY = drawHeight / Math.max(1, rectangle.height)
const lightRadius = Math.max(4, resolvedLightSpot.radius * ((lightScaleX + lightScaleY) / 2))
const mappedLightSpot = mapLocalLightSpotToWorld(normalizedRule, resolvedLightSpot.x, resolvedLightSpot.y)
const lightCenterX = mappedLightSpot.x
const lightCenterY = mappedLightSpot.y
const hitboxValue = hitbox || { x: 0, y: 0, width: 0, height: 0 }
const hitboxX = toFiniteNumber(hitboxValue.x, 0) ?? 0
const hitboxY = toFiniteNumber(hitboxValue.y, 0) ?? 0
const hitboxWidth = clampMin(toFiniteNumber(hitboxValue.width, 1) ?? 1)
const hitboxHeight = clampMin(toFiniteNumber(hitboxValue.height, 1) ?? 1)
const hitboxScaleX = drawWidth / Math.max(1, rectangle.width)
const hitboxScaleY = drawHeight / Math.max(1, rectangle.height)
const resolvedZIndexOffset = toFiniteNumber(zIndexOffset(), 0) ?? 0
const hasSortableHitbox = hitbox && hitbox.type !== "none"
const elementSortY = hasSortableHitbox
    ? drawY + (hitboxY * hitboxScaleY)
    : drawY + drawHeight
const resolvedElementZIndex = Math.round(elementSortY + resolvedZIndexOffset)
const resolvedLightSpotZIndex = resolvedElementZIndex - 2

const lightSpotOverlay = {
    enabled: resolvedLightSpot.enabled,
    centerX: lightCenterX,
    centerY: lightCenterY,
    radius: lightRadius,
    renderRadius: lightRadius * lightStyleRadiusScale(resolvedLightSpot.style),
    intensity: resolvedLightSpot.intensity / 100,
    flicker: resolvedLightSpot.flicker,
    flickerSpeed: resolvedLightSpot.flickerSpeed,
    style: resolvedLightSpot.style,
    zIndex: resolvedLightSpotZIndex
}

const readValue = (value) => typeof value === "function" ? value() : value

const studioLightSpotId = [
    "studio-element",
    readValue(id) ?? "unknown",
    Math.round(drawX),
    Math.round(drawY),
    Math.round(lightCenterX),
    Math.round(lightCenterY)
].join(":")

const syncLightSpotWithSceneMap = () => {
    if (!engine?.sceneMap) return
    if (!lightSpotOverlay.enabled) {
        engine.sceneMap.removeLightSpot(studioLightSpotId)
        return
    }

    engine.sceneMap.addLightSpot(studioLightSpotId, {
        id: studioLightSpotId,
        x: lightSpotOverlay.centerX,
        y: lightSpotOverlay.centerY,
        radius: lightSpotOverlay.renderRadius,
        intensity: lightSpotOverlay.intensity,
        flicker: lightSpotOverlay.flicker,
        flickerSpeed: lightSpotOverlay.flickerSpeed,
    })
}

const onBeforeDestroy = () => {
    engine?.sceneMap?.removeLightSpot(studioLightSpotId)
}

mount(() => {
    syncLightSpotWithSceneMap()
})

const spriteParts = buildSegmentsWithRule(normalizedRule) ?? fallbackSpriteParts

const shadow = {
    x: drawX + (hitboxX * hitboxScaleX) + (hitboxWidth * hitboxScaleX),
    y: drawY + (hitboxY * hitboxScaleY) + (hitboxHeight * hitboxScaleY),
    width: (hitboxWidth * hitboxScaleX) / 2,
    height: (hitboxHeight * hitboxScaleY) / 2
}

let zIndex = signal(0)
zIndex.set(resolvedElementZIndex)
</script>
