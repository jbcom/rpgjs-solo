<Container scale>
    <StudioTerrainMap data splitWallForeground={true} /> 
    <Container sortableChildren={true} pixiChildren={terrainWallShadowPixiChildren} />
    <Container sortableChildren={true} pixiChildren={elementsAlwaysLowPixiChildren} />
    <EventLayerComponent pixiChildren={eventLayerPixiChildren} /> 
    <Container sortableChildren={true} pixiChildren={elementsHighPixiChildren} />
</Container>

@if (weatherOptions) {
  <Weather
      effect={weatherOptions().effect}
      density={weatherOptions().density}
      speed={weatherOptions().speed}
      windDirection={weatherOptions().windDirection}
      windStrength={weatherOptions().windStrength}
      maxDrops={weatherOptions().maxDrops}
      scale={weatherOptions().scale}
      height={weatherOptions().height}
      sunIntensity={weatherOptions().sunIntensity}
      sunAngle={weatherOptions().sunAngle}
      raySpread={weatherOptions().raySpread}
      rayTwinkle={weatherOptions().rayTwinkle}
      rayTwinkleSpeed={weatherOptions().rayTwinkleSpeed}
      alpha={weatherOptions().alpha}
      zIndex={weatherOptions().zIndex}
    />
}

  <script>
    import { computed, effect, mount, signal, tick } from 'canvasengine'
    import { Weather } from "@canvasengine/presets";
    import { EventLayerComponent, RpgClientEngine, inject } from "@rpgjs/client";
    import { Container as PixiContainer, Graphics } from "pixi.js";
    import StudioTerrainMap from '../map-renderer/components/studio-terrain-map.ce'
    import { StudioTerrainWallOcclusionRenderer, StudioTerrainWallShadowRenderer } from '../map-renderer/terrain-renderer/terrain-chunk-renderer'
    import { StudioElementRenderer } from '../map-renderer/studio-element-renderer'
    import { toCanvasWeatherOptions } from '@common/weather';
    import { assetsUrl } from "../constants";
    import { createViewportCullKey, getPixiLocalViewportBounds } from '../map-renderer/viewport-culling'

    const { data } = defineProps()

    const engine = inject(RpgClientEngine);
    const terrainWallShadowWorld = new PixiContainer()
    const elementsAlwaysLowWorld = new PixiContainer()
    const elementsHighWorld = new PixiContainer()
    const terrainWallShadowMask = new Graphics()
    const elementsAlwaysLowMask = new Graphics()
    const elementsHighMask = new Graphics()
    terrainWallShadowWorld.sortableChildren = true
    elementsAlwaysLowWorld.sortableChildren = true
    elementsHighWorld.sortableChildren = true
    terrainWallShadowWorld.mask = terrainWallShadowMask
    elementsAlwaysLowWorld.mask = elementsAlwaysLowMask
    elementsHighWorld.mask = elementsHighMask
    const terrainWallShadowPixiChildren = [terrainWallShadowWorld, terrainWallShadowMask]
    const elementsAlwaysLowPixiChildren = [elementsAlwaysLowWorld, elementsAlwaysLowMask]
    const elementsHighPixiChildren = [elementsHighWorld, elementsHighMask]
    let terrainWallShadowChildren = []
    let elementsAlwaysLowChildren = []
    const terrainWallOcclusionChildren = signal([])
    const elementsLowPixiChildren = signal([])
    let elementsHighChildren = []
    const eventLayerPixiChildren = computed(() => {
      return [
        ...elementsLowPixiChildren(),
        ...terrainWallOcclusionChildren()
      ]
    })
    const terrainWallOcclusionRenderer = new StudioTerrainWallOcclusionRenderer()
    const terrainWallShadowRenderer = new StudioTerrainWallShadowRenderer()
    const elementsAlwaysLowRenderer = new StudioElementRenderer()
    const elementsLowRenderer = new StudioElementRenderer()
    const elementsHighRenderer = new StudioElementRenderer()
    let terrainWallOcclusionSerial = 0
    let terrainWallShadowSerial = 0
    let studioElementRenderSerial = 0
    const STUDIO_ELEMENT_SHADOW_CASTER_LIMIT = 1000
    const TERRAIN_MORPHOLOGY_CULL_MARGIN = 1024
    const TERRAIN_MORPHOLOGY_CULL_GRID_SIZE = 128
    let lastTerrainMorphologyCullKey = ""

    tick(({ deltaTime }) => {
      elementsAlwaysLowRenderer.update(deltaTime)
      elementsLowRenderer.update(deltaTime)
      elementsHighRenderer.update(deltaTime)
      updateTerrainMorphologyCulling()
    })

    const syncPixiWorldChildren = (world, children) => {
      const nextChildren = Array.isArray(children) ? children.filter(Boolean) : []
      const currentChildren = [...world.children]
      currentChildren.forEach((child) => {
        if (!nextChildren.includes(child)) {
          world.removeChild(child)
        }
      })
      nextChildren.forEach((child) => {
        if (child.parent === world) return
        if (child.parent) {
          child.parent.removeChild(child)
        }
        world.addChild(child)
      })
    }

    const updateMapMask = (mask, bounds) => {
      mask.clear()
      mask.rect(0, 0, bounds.width, bounds.height)
      mask.fill(0xffffff)
    }

    const tilesetImage = computed(() => {
      const params = data().params
      if (!params?.tileset?.fileName) return ''
      return `${assetsUrl}/${params.tileset.fileName}`
    })

    const renderTerrainWallOcclusion = async () => {
      const mapData = data()
      if (!mapData) return
      const currentSerial = ++terrainWallOcclusionSerial
      const children = await terrainWallOcclusionRenderer.renderMap(mapData)
      if (currentSerial !== terrainWallOcclusionSerial) return
      terrainWallOcclusionChildren.set(children)
      lastTerrainMorphologyCullKey = ""
      updateTerrainMorphologyCulling()
    }

    const mapLighting = computed(() => {
      const mapData = data()
      return mapData?.lighting ?? engine.sceneMap.lighting?.() ?? null
    })

    const renderTerrainWallShadows = async () => {
      const mapData = data()
      if (!mapData) return
      const currentSerial = ++terrainWallShadowSerial
      const children = await terrainWallShadowRenderer.renderMap(mapData, mapLighting())
      if (currentSerial !== terrainWallShadowSerial) return
      terrainWallShadowChildren = children
      syncPixiWorldChildren(terrainWallShadowWorld, terrainWallShadowChildren)
      lastTerrainMorphologyCullKey = ""
      updateTerrainMorphologyCulling()
    }

    effect(() => {
      data()
      void renderTerrainWallOcclusion()
    })

    effect(() => {
      data()
      mapLighting()
      void renderTerrainWallShadows()
    })

    mount(() => {
      return () => {
        terrainWallOcclusionSerial += 1
        terrainWallShadowSerial += 1
        studioElementRenderSerial += 1
        lastTerrainMorphologyCullKey = ""
        terrainWallShadowChildren = []
        terrainWallOcclusionChildren.set([])
        elementsAlwaysLowChildren = []
        elementsLowPixiChildren.set([])
        elementsHighChildren = []
        syncPixiWorldChildren(terrainWallShadowWorld, terrainWallShadowChildren)
        syncPixiWorldChildren(elementsAlwaysLowWorld, elementsAlwaysLowChildren)
        syncPixiWorldChildren(elementsHighWorld, elementsHighChildren)
        terrainWallOcclusionRenderer.destroy()
        terrainWallShadowRenderer.destroy()
        elementsAlwaysLowRenderer.destroy(engine.sceneMap)
        elementsLowRenderer.destroy(engine.sceneMap)
        elementsHighRenderer.destroy(engine.sceneMap)
      }
    })

    function updateTerrainMorphologyCulling() {
      const bounds = getPixiLocalViewportBounds(engine, terrainWallShadowWorld)
      if (!bounds) {
        if (lastTerrainMorphologyCullKey) {
          lastTerrainMorphologyCullKey = ""
          terrainWallOcclusionRenderer.updateSpriteVisibility(null)
          terrainWallShadowRenderer.updateSpriteVisibility(null)
        }
        return
      }

      const cullKey = createViewportCullKey(bounds, TERRAIN_MORPHOLOGY_CULL_GRID_SIZE)
      if (cullKey === lastTerrainMorphologyCullKey) {
        return
      }

      lastTerrainMorphologyCullKey = cullKey
      terrainWallOcclusionRenderer.updateSpriteVisibility(bounds, TERRAIN_MORPHOLOGY_CULL_MARGIN)
      terrainWallShadowRenderer.updateSpriteVisibility(bounds, TERRAIN_MORPHOLOGY_CULL_MARGIN)
    }

    const terrainImage = computed(() => {
      const params = data().params
      if (!params?.baseTerrain?.fileName) return ''
      return `${assetsUrl}/${params.baseTerrain.fileName}`
    })

    const normalizeTilesets = (tilesets) => {
      if (!tilesets) return []
      if (Array.isArray(tilesets)) return tilesets
      if (tilesets.items && Array.isArray(tilesets.items)) return tilesets.items
      return []
    }

    const parseArrayData = (value) => {
      if (Array.isArray(value)) return value
      if (typeof value === 'string' && value.trim()) {
        try {
          const parsed = JSON.parse(value)
          return Array.isArray(parsed) ? parsed : []
        }
        catch (_error) {
          return []
        }
      }
      return []
    }

    const toPositiveNumber = (value) => {
      const number = Number(value)
      return Number.isFinite(number) && number > 0 ? number : null
    }

    const parseTsxMetadata = (value) => {
      if (typeof value !== 'string' || !value.trim()) {
        return {}
      }

      const readAttribute = (tag, attribute) => {
        const match = value.match(new RegExp(`<${tag}\\b[^>]*\\b${attribute}="([^"]+)"`))
        return match?.[1]
      }

      return {
        tilewidth: toPositiveNumber(readAttribute('tileset', 'tilewidth')),
        tileheight: toPositiveNumber(readAttribute('tileset', 'tileheight')),
        tilecount: toPositiveNumber(readAttribute('tileset', 'tilecount')),
        columns: toPositiveNumber(readAttribute('tileset', 'columns')),
        imagewidth: toPositiveNumber(readAttribute('image', 'width')),
        imageheight: toPositiveNumber(readAttribute('image', 'height'))
      }
    }

    const getTilesetMetadata = (tileset) => {
      const metadata = tileset?.metadata || {}
      const tsxMetadata = parseTsxMetadata(metadata.tsx)

      return {
        tilewidth: toPositiveNumber(metadata.tilewidth) || tsxMetadata.tilewidth,
        tileheight: toPositiveNumber(metadata.tileheight) || tsxMetadata.tileheight,
        tilecount: toPositiveNumber(metadata.tilecount) || tsxMetadata.tilecount,
        columns: toPositiveNumber(metadata.columns) || tsxMetadata.columns,
        imagewidth: toPositiveNumber(metadata.imagewidth) || tsxMetadata.imagewidth,
        imageheight: toPositiveNumber(metadata.imageheight) || tsxMetadata.imageheight
      }
    }

    const getMaxTileId = (tiles) => {
      let max = -1
      const visit = (value) => {
        if (Array.isArray(value)) {
          value.forEach(visit)
          return
        }
        const number = Number(value)
        if (Number.isFinite(number) && number >= 0) {
          max = Math.max(max, number)
        }
      }
      visit(tiles)
      return max
    }

    const normalizeIdentifier = (value) => {
      if (value === null || value === undefined) return ''
      let result = String(value).trim()
      if (!result) return ''
      const objectIdMatch =
        result.match(/^ObjectId\("([^"]+)"\)$/) || result.match(/^ObjectId\('([^']+)'\)$/)
      if (objectIdMatch?.[1]) {
        result = objectIdMatch[1]
      }
      if (result.startsWith('#')) {
        result = result.slice(1)
      }
      return result
    }

    const resolveTilesetId = (value) => {
      if (!value) return ''
      if (typeof value === 'string' || typeof value === 'number') return normalizeIdentifier(value)
      return normalizeIdentifier(value?._id || value?.id)
    }

    const getTerrainTilesets = () => {
      const params = data().params || {}
      return normalizeTilesets(params.terrainTilesets || params.terrainTileset || params.terrain || params.tilesets?.terrain)
    }

    const getElementTilesets = () => {
      const params = data().params || {}
      return normalizeTilesets(params.elementTilesets || params.tilesets || params.elementsTilesets)
    }

    const tilesetImageById = computed(() => {
      const params = data().params || {}
      const map = new Map()
      const elementTilesets = getElementTilesets()
      elementTilesets.forEach((tileset) => {
        const id = resolveTilesetId(tileset)
        const fileName = tileset?.fileName || tileset?.image
        if (id && fileName) {
          map.set(id, `${assetsUrl}/${fileName}`)
        }
      })
      if (params?.tileset?.fileName) {
        const fallbackId = resolveTilesetId(params?.tileset) || 'default'
        map.set(fallbackId, `${assetsUrl}/${params.tileset.fileName}`)
      }
      return map
    })

    const getElementImage = (obj) => {
      if (obj?.image) return obj.image
      const tilesetId = resolveTilesetId(obj?.tilesetId)
      if (tilesetId && tilesetImageById().has(tilesetId)) {
        return tilesetImageById().get(tilesetId)
      }
      return tilesetImage()
    }

    const withElementImages = (elements) => {
      return elements.map((element) => ({
        ...element,
        image: getElementImage(element)
      }))
    }

    const map = computed(() => {
      const params = data().params
      const terrain = parseArrayData(data().terrain)

      if (!params) {
        return null
      }

      const configuredTerrainTilesets = getTerrainTilesets()
      const terrainTilesets = configuredTerrainTilesets.length > 0
        ? configuredTerrainTilesets
        : (params.primaryTerrainTileset
          ? [params.primaryTerrainTileset]
          : (params.baseTerrain ? [params.baseTerrain] : []))
      const primaryTerrainId = resolveTilesetId(params.primaryTerrainTileset) || resolveTilesetId(params.baseTerrain)
      const primaryTerrainTileset = (primaryTerrainId
        ? terrainTilesets.find((tileset) => resolveTilesetId(tileset) === primaryTerrainId)
        : null) || terrainTilesets[0] || params.baseTerrain || null
      const baseTerrainMeta = getTilesetMetadata(params.baseTerrain)
      const primaryTerrainMeta = getTilesetMetadata(primaryTerrainTileset)
      const fallbackTileWidth = baseTerrainMeta.tilewidth || 48
      const fallbackTileHeight = baseTerrainMeta.tileheight || 48
      const tileWidth = primaryTerrainMeta.tilewidth || fallbackTileWidth
      const tileHeight = primaryTerrainMeta.tileheight || fallbackTileHeight
      const currentTerrainImage = terrainImage()

      const terrainGrid = Array.isArray(terrain) && Array.isArray(terrain[0]) ? terrain : null
      const terrainFlat = Array.isArray(terrain) && !Array.isArray(terrain[0]) ? terrain : null
      const tilesetsForMap = primaryTerrainTileset ? [primaryTerrainTileset] : []
      const maxTerrainTileId = getMaxTileId(terrain)

      let gidOffset = 1
      const tiledTilesets = tilesetsForMap.map((tileset) => {
        const meta = getTilesetMetadata(tileset)
        const imageWidth = meta.imagewidth || (meta.columns ? meta.columns * tileWidth : tileWidth)
        const columns = meta.columns || Math.floor(imageWidth / tileWidth) || 1
        const imageHeight = meta.imageheight || tileHeight * Math.ceil(Math.max(meta.tilecount || 1, maxTerrainTileId + 1, 1) / columns)
        const imageTileCount = columns * Math.floor(imageHeight / tileHeight)
        const tilecount = Math.max(meta.tilecount || 0, imageTileCount, maxTerrainTileId + 1, 1)
        const firstgid = gidOffset
        gidOffset += tilecount || 0
        const imageSource = tileset?.fileName ? `${assetsUrl}/${tileset.fileName}` : currentTerrainImage
        return {
          firstgid,
          name: tileset?.name || 'Tileset',
          image: {
            source: imageSource,
            width: imageWidth,
            height: imageHeight
          },
          tilewidth: meta.tilewidth || tileWidth,
          tileheight: meta.tileheight || tileHeight,
          tilecount: tilecount || 1,
          columns
        }
      })

      const width = params.width || 50
      const height = params.height || 50

      const buildLayerData = () => {
        const size = width * height
        const dataLayer = new Array(size).fill(0)

        if (terrainGrid) {
          const firstgid = tiledTilesets[0]?.firstgid || 1
          for (let y = 0; y < height; y += 1) {
            for (let x = 0; x < width; x += 1) {
              const tile = terrainGrid?.[y]?.[x]
              if (tile === null || tile === undefined || tile < 0) continue
              dataLayer[y * width + x] = firstgid + Number(tile)
            }
          }
          return dataLayer
        }

        if (terrainFlat) {
          const firstgid = tiledTilesets[0]?.firstgid || 1
          for (let i = 0; i < size; i += 1) {
            const tile = terrainFlat[i]
            if (tile === null || tile === undefined || tile < 0) continue
            dataLayer[i] = firstgid + Number(tile)
          }
          return dataLayer
        }

        return dataLayer
      }

      return {
        type: 'map',
        version: 1.9,
        tiledversion: '1.9.2',
        orientation: 'orthogonal',
        renderorder: 'right-down',
        width: params.width || 50,
        height: params.height || 50,
        tilewidth: tileWidth,
        tileheight: tileHeight,
        infinite: false,
        nextlayerid: 5,
        nextobjectid: 14,
        tilesets: tiledTilesets,
        layers: [
          {
            id: 1,
            name: 'Terrain Layer',
            type: 'tilelayer',
            tilewidth: tileWidth,
            tileheight: tileHeight,
            width,
            height,
            data: buildLayerData()
          }
        ]
      }
    })

    const scale = computed(() => {
      const params = data().params
      return params?.scale || 1
    })

    const mapBounds = computed(() => {
      const mapData = map()
      const renderData = data()?.terrainRenderData
      const width =
        Number(renderData?.width) ||
        Math.max(1, Math.floor(Number(mapData?.width) || 50)) * (Number(mapData?.tilewidth) || 48)
      const height =
        Number(renderData?.height) ||
        Math.max(1, Math.floor(Number(mapData?.height) || 50)) * (Number(mapData?.tileheight) || 48)

      return { width, height }
    })

    effect(() => {
      const bounds = mapBounds()
      updateMapMask(terrainWallShadowMask, bounds)
      updateMapMask(elementsAlwaysLowMask, bounds)
      updateMapMask(elementsHighMask, bounds)
    })

    const elementsAlwaysLow = computed(() => data().elementsAlwaysLow || [])
    const elementsLow = computed(() => {
      return data().elementsLow || []
    })
    const elementsHigh = computed(() => data().elementsHigh || [])

    const renderStudioElements = async () => {
      const currentSerial = ++studioElementRenderSerial
      const shadowBudget = { remaining: STUDIO_ELEMENT_SHADOW_CASTER_LIMIT }
      const renderOptions = {
        sceneMap: engine.sceneMap,
        lighting: mapLighting(),
        shadowBudget,
        shadowCasterLimit: STUDIO_ELEMENT_SHADOW_CASTER_LIMIT
      }

      const alwaysLowChildren = await elementsAlwaysLowRenderer.renderElements(
        withElementImages(elementsAlwaysLow()),
        renderOptions
      )
      if (currentSerial !== studioElementRenderSerial) return

      const lowChildren = await elementsLowRenderer.renderElements(
        withElementImages(elementsLow()),
        renderOptions
      )
      if (currentSerial !== studioElementRenderSerial) return

      const highChildren = await elementsHighRenderer.renderElements(
        withElementImages(elementsHigh()),
        renderOptions
      )
      if (currentSerial !== studioElementRenderSerial) return

      elementsAlwaysLowChildren = alwaysLowChildren
      syncPixiWorldChildren(elementsAlwaysLowWorld, elementsAlwaysLowChildren)
      elementsLowPixiChildren.set(lowChildren)
      elementsHighChildren = highChildren
      syncPixiWorldChildren(elementsHighWorld, elementsHighChildren)
    }

    effect(() => {
      data()
      tilesetImageById()
      tilesetImage()
      mapLighting()
      void renderStudioElements()
    })

    const players = computed(() => engine.sceneMap.players)
    const events = computed(() => engine.sceneMap.events)

    effect(() => {
      engine.sceneMap.setLocalWeather(data().weather ?? data().params?.weather ?? null);
    })

    const weatherOptions = computed(() => {
      const sceneMapWeather = (engine.sceneMap as any).weather;
      const effectiveWeather = sceneMapWeather();
      if (!effectiveWeather) {
        return null;
      }
      return toCanvasWeatherOptions(effectiveWeather);
    })
  </script>
