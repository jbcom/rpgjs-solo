{
  "name": "@rpgjs/studio",
  "version": "5.0.0-beta.12",
  "main": "dist/client/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "exports": {
    ".": {
      "import": "./dist/client/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./runtime/*": {
      "import": "./dist/runtime/*.js",
      "types": "./dist/runtime/*.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/src/server.d.ts"
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "RPGJS is a framework for creating RPG/MMORPG games",
  "peerDependencies": {
    "@canvasengine/presets": "^2.0.0-rc.4",
    "@rpgjs/action-battle": "workspace:*",
    "@rpgjs/client": "workspace:*",
    "@rpgjs/common": "workspace:*",
    "@rpgjs/server": "workspace:*",
    "@rpgjs/vite": "workspace:*",
    "canvasengine": "^2.0.0-rc.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@canvasengine/compiler": "2.0.0-rc.4",
    "pixi.js": "^8.18.1",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0"
  },
  "type": "module"
}
