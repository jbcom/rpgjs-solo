{
  "name": "@jbcom/rpgjs-solo-renderer",
  "version": "5.0.0-beta.26.solo.0",
  "description": "Native CanvasEngine renderer and Tiled authoring surface for RPGJS Solo",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:boundary": "node scripts/verify-boundary.mjs"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://git.local.jonbogaty.com/api/packages/jbcom/npm/"
  },
  "dependencies": {
    "@canvasengine/presets": "2.0.0",
    "@canvasengine/tiled": "2.0.0",
    "@jbcom/rpgjs-solo": "workspace:5.0.0-beta.26.solo.0",
    "canvasengine": "2.0.1"
  },
  "peerDependencies": {
    "pixi.js": "8.19.0"
  },
  "devDependencies": {
    "pixi.js": "8.19.0",
    "typescript": "^6.0.3",
    "vite": "8.1.1",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
